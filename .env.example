# ============================================================
# MCP UNIFIED — ENVIRONMENT / CREDENTIAL REFERENCE
# ============================================================
# You do NOT need to fill these manually.
# Use the Web Dashboard (npm run dev) to configure everything.
# Credentials are stored AES-256-GCM encrypted in SQLite.
# ============================================================

# -- Master encryption key (auto-generated on first run) -----
# Override with your own passphrase for portability:
# MASTER_SECRET=your-strong-passphrase

# -- Config / DB directory (default: ~/.mcp-unified) ----------
# MCP_DATA_DIR=~/.mcp-unified

# -- Dashboard API port (default: 3001) -----------------------
# API_PORT=3001

# ============================================================
# GOOGLE (Gmail + Drive + Calendar + YouTube)
# ============================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
# (OAuth tokens saved automatically after connecting in dashboard)

# ============================================================
# NOTION
# ============================================================
# NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# TELEGRAM
# ============================================================
# TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# WHATSAPP — choose one provider
# ============================================================
# Provider: twilio | meta  (default: twilio)
# WHATSAPP_PROVIDER=twilio

# Twilio:
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta Cloud API:
# META_WHATSAPP_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=

# ============================================================
# LINKEDIN
# ============================================================
# LINKEDIN_EMAIL=your@email.com
# LINKEDIN_PASSWORD=your_linkedin_password

# ============================================================
# OUTLOOK / MICROSOFT 365 (optional)
# ============================================================
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=common
# MS_REDIRECT_URI=http://localhost:3001/auth/outlook/callback
